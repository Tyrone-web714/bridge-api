PORT=5000
GOOGLE_MAPS_API_KEY=your_server_side_google_maps_key
CORS_ORIGIN=*
ADMIN_DASHBOARD_PASSWORD=choose-a-strong-supervisor-password
ADMIN_DASHBOARD_SECRET=choose-a-long-random-secret-for-cookie-signing
ADMIN_DASHBOARD_ADMINS=admin
ADMIN_DASHBOARD_ROLE=supervisor
ADMIN_CREATE_USERNAME=admin
ADMIN_CREATE_PASSWORD=change-this-to-a-strong-temporary-password
ADMIN_CREATE_ROLE=admin
ADMIN_CREATE_DISPLAY_NAME=Supervisor Admin
DRIVER_API_TOKEN=replace-with-a-random-driver-app-token-at-least-32-chars
DRIVER_SESSION_HOURS=16
# Development migration fallback only. Keep false in production.
ALLOW_LEGACY_DRIVER_API_TOKEN=false
MAX_BULK_IMPORT_ROWS=100000
BULK_IMPORT_WRITE_CONCURRENCY=8

# OpenAI analysis layer. Keep the key on the backend only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=30000
# Optional usage-cost estimates. Set these to the current model rates from your OpenAI account.
OPENAI_INPUT_COST_PER_MILLION_USD=
OPENAI_OUTPUT_COST_PER_MILLION_USD=

# PostgreSQL database. When this is set, mutable backend data uses PostgreSQL.
# If it is not set, the app keeps using the local JSON files for development.
DATABASE_URL=postgres://username:password@localhost:5432/truck_safe_routing
DATABASE_SSL=false

# Delivery-note photo storage.
# Use local for development. Use s3 for production pilot durable object storage.
PHOTO_STORAGE_PROVIDER=local
PHOTO_STORAGE_LOCAL_DIR=data/delivery_note_photos
BACKEND_PUBLIC_URL=http://localhost:5000
DELIVERY_NOTE_MAX_PHOTOS=4
DELIVERY_NOTE_MAX_PHOTO_BYTES=6000000
REQUEST_BODY_LIMIT=1mb
DELIVERY_BODY_LIMIT=30mb
MANIFEST_BODY_LIMIT=12mb
IMPORT_BODY_LIMIT=15mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=1200
RATE_LIMIT_AUTH_MAX=12
RATE_LIMIT_DRIVER_MAX=600
RATE_LIMIT_PLACES_MAX=240
RATE_LIMIT_AI_MAX=60
RATE_LIMIT_UPLOAD_MAX=120
AUDIT_LOG_HASH_SECRET=replace-with-a-separate-random-secret

# Required when PHOTO_STORAGE_PROVIDER=s3.
PHOTO_STORAGE_BUCKET=truck-safe-routing-delivery-photos
PHOTO_STORAGE_REGION=us-east-1
PHOTO_STORAGE_ENDPOINT=
PHOTO_STORAGE_FORCE_PATH_STYLE=false
PHOTO_STORAGE_ACCESS_KEY_ID=
PHOTO_STORAGE_SECRET_ACCESS_KEY=
PHOTO_STORAGE_PUBLIC_BASE_URL=https://your-photo-cdn-or-bucket-url.example
PHOTO_MIGRATION_DELETE_LOCAL=false

# Production pilot readiness:
# - Set CORS_ORIGIN to the deployed app/web origins, not "*".
# - Use DATABASE_SSL=true for hosted PostgreSQL providers that require SSL.
# - Set PHOTO_STORAGE_PROVIDER=s3 before pilot so delivery-note photos are durable.
# - Run npm.cmd run verify:production before pointing the mobile app to the deployed API.
ORGANIZATION_NAME=TruckSafe Routing
