# Truck-Safe Routing repository-wide ignores

# dependencies
node_modules/
**/node_modules/

# environment and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p8
*.p12
*.jks
*.mobileprovision

# logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# build outputs and caches
dist/
build/
coverage/
.cache/
.tmp/
tmp/

# Expo/mobile local state and generated artifacts
.expo/
**/.expo/
.expo-export-*/
**/.expo-export-*/
web-build/
**/web-build/
*.apk
*.aab
truck-safe-routing-*-apk-qr.png
truck-marker-current-preview.png
truck-sprite-contact-sheet.png

# generated native mobile folders
apps/mobile/android/
apps/mobile/ios/

# OS/editor files
.DS_Store
Thumbs.db
